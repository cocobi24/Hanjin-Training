# Gemini API
VITE_GEMINI_API_KEY=여기에_키_붙여넣기
VITE_GEMINI_MODEL=gemini-3.5-flash

# Google OAuth (시나리오 02 - Gmail / Calendar 연동)
VITE_GOOGLE_CLIENT_ID=여기에_구글_클라이언트_ID_붙여넣기

# Google Chat Webhook (시나리오 03 - Chat 발송)
# Google Chat Space > 앱 및 통합 > Webhook에서 발급
VITE_GOOGLE_CHAT_WEBHOOK_URL=여기에_웹훅_URL_붙여넣기
